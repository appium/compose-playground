{
  "name": "compose-playground",
  "version": "1.1.0",
  "description": "Jetpack Compose fixture app for Android UI exploration and testing",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./index.mjs",
  "types": "./index.d.mts",
  "exports": {
    ".": {
      "types": "./index.d.mts",
      "default": "./index.mjs"
    }
  },
  "scripts": {
    "bump-gradle-version": "node ./scripts/gradle-version-update.mjs --package-version=${npm_package_version} && git add app/build.gradle.kts",
    "build": "npm run build:debug",
    "build:debug": "./gradlew assembleDebug",
    "build:release": "./gradlew assembleRelease",
    "build:clean": "./gradlew clean",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "version": "npm run bump-gradle-version",
    "clean": "rm -rf node_modules && rm -f package-lock.json && npm install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appium/compose-playground.git"
  },
  "keywords": [
    "android",
    "jetpack-compose",
    "ui-testing",
    "instrumented-tests"
  ],
  "author": "Appium Contributors",
  "bugs": {
    "url": "https://github.com/appium/compose-playground/issues"
  },
  "homepage": "https://github.com/appium/compose-playground",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "files": [
    "./index.mjs",
    "./index.d.mts",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@appium/eslint-config-appium-ts": "^3.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "semantic-release": "^25.0.0",
    "semver": "^7.3.7"
  }
}
